# ============================================================
# .htaccess — Makhazen Alenayah Performance
# ============================================================

Options -Indexes

# ---- Gzip Compression ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
  AddOutputFilterByType DEFLATE text/plain text/xml application/xml image/svg+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2 application/font-woff application/font-woff2
</IfModule>

# ---- Browser Caching ----
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — لا تُكش
  ExpiresByType text/html                  "access plus 0 seconds"

  # CSS & JS — ساعة واحدة (يمكن رفعها بعد إضافة versioning)
  ExpiresByType text/css                   "access plus 1 week"
  ExpiresByType application/javascript     "access plus 1 week"

  # صور
  ExpiresByType image/webp                 "access plus 1 month"
  ExpiresByType image/png                  "access plus 1 month"
  ExpiresByType image/jpeg                 "access plus 1 month"
  ExpiresByType image/svg+xml             "access plus 1 month"
  ExpiresByType image/x-icon              "access plus 1 year"

  # خطوط
  ExpiresByType font/woff                  "access plus 1 year"
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType application/font-woff      "access plus 1 year"
  ExpiresByType application/font-woff2     "access plus 1 year"
</IfModule>

# ---- Cache-Control Headers ----
<IfModule mod_headers.c>
  # صور وخطوط وCSS وJS → immutable مع versioning أو طويل
  <FilesMatch "\.(webp|png|jpg|jpeg|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # Keep-Alive
  Header set Connection keep-alive

  # Remove ETags (already handled by Expires)
  Header unset ETag
  FileETag None
</IfModule>

# ---- PHP Performance ----
<IfModule mod_php8.c>
  php_value output_buffering 4096
</IfModule>

# ---- URL Rewriting (optional) ----
<IfModule mod_rewrite.c>
  RewriteEngine On
</IfModule>
