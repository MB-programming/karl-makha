# ============================================================
# .htaccess — Makhazen Alenayah Performance & Caching
# ============================================================

Options -Indexes

# ---- Brotli Compression (أسرع من Gzip) ----
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript
  AddOutputFilterByType BROTLI_COMPRESS application/json text/xml application/xml
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml font/woff font/woff2
</IfModule>

# ---- Gzip Compression (fallback) ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
  AddOutputFilterByType DEFLATE text/plain text/xml application/xml image/svg+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2 application/font-woff application/font-woff2
  # Fix for some browsers
  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

# ---- Browser Caching — 1 Year for all static assets ----
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — no cache (dynamic content)
  ExpiresByType text/html                  "access plus 0 seconds"

  # CSS & JS — 1 year (use ?v=xxx versioning in HTML if needed)
  ExpiresByType text/css                   "access plus 1 year"
  ExpiresByType application/javascript     "access plus 1 year"

  # صور — سنة كاملة
  ExpiresByType image/webp                 "access plus 1 year"
  ExpiresByType image/png                  "access plus 1 year"
  ExpiresByType image/jpeg                 "access plus 1 year"
  ExpiresByType image/gif                  "access plus 1 year"
  ExpiresByType image/svg+xml              "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon  "access plus 1 year"

  # خطوط — سنة
  ExpiresByType font/woff                  "access plus 1 year"
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType application/font-woff      "access plus 1 year"
  ExpiresByType application/font-woff2     "access plus 1 year"
  ExpiresByType font/ttf                   "access plus 1 year"
  ExpiresByType font/otf                   "access plus 1 year"

  # JSON & XML — 5 min
  ExpiresByType application/json           "access plus 5 minutes"
  ExpiresByType application/xml            "access plus 5 minutes"
</IfModule>

# ---- Cache-Control Headers (explicit — overrides Expires for modern browsers) ----
<IfModule mod_headers.c>

  # صور وخطوط → immutable (لا تتغير طالما نفس الاسم)
  <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header unset Last-Modified
  </FilesMatch>

  # CSS & JS → شهر (بدون immutable لأنها بتتغير — استخدم ?v=x في الـ HTML)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML & PHP → no cache
  <FilesMatch "\.(html|php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # CORS للخطوط
  <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>

  # Security headers
  Header set X-Content-Type-Options "nosniff"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Keep-Alive
  Header set Connection keep-alive

  # Remove ETags (Expires كافي)
  Header unset ETag
  FileETag None
</IfModule>

# ---- PHP Performance ----
<IfModule mod_php8.c>
  php_value output_buffering 4096
  php_flag zlib.output_compression On
</IfModule>
<IfModule mod_php7.c>
  php_value output_buffering 4096
  php_flag zlib.output_compression On
</IfModule>

# ---- URL Rewriting ----
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect HTTP → HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>
